# Anthropic — Claude Agent SDK
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Composio — MCP tool connectivity and OAuth
COMPOSIO_API_KEY=your_composio_api_key_here
# Comma-separated Composio toolkit slugs the agent mounts as MCP tools — align with what you
# connect under Dashboard → Integrations (e.g. gmail,googlecalendar). Restart after changes.
COMPOSIO_TOOLKITS=

# Sendblue — iMessage / SMS bridge (required values live in env only; not stored in SQLite)
SENDBLUE_API_KEY_ID=your_sendblue_api_key_id
SENDBLUE_API_SECRET_KEY=your_sendblue_api_secret_key
# The Sendblue number Muffs sends FROM (E.164 format, e.g. +15551234567)
SENDBLUE_FROM_NUMBER=+15551234567
# Your iPhone number Muffs sends TO (E.164 format; also used to validate inbound webhook sender)
SENDBLUE_TO_NUMBER=+15559876543
# Optional: pin inbound iMessage/SMS to a specific dashboard session id (otherwise uses latest chat).
# MUFFS_SENDBLUE_SESSION_ID=sess_1234567890

# Workspace root (default: ~/muffs-workspace on macOS, ~/.local/share/muffs on Linux, %APPDATA%/Muffs on Windows).
# Holds workspace/memory/, workspace/projects/, workspace/user/preferences.json, and db/muffs.db.
# MUFFS_WORKSPACE=

# Optional: session auto-rotate when context > 90% (default true). Overrides preferences.json.
# MUFFS_AUTO_ROTATE_SESSION=true

# Override paths if you do not want defaults under MUFFS_WORKSPACE:
# DB_PATH=$HOME/.local/share/muffs/db/muffs.db
# MEMORY_PATH=$HOME/.local/share/muffs/workspace/memory/memory.md
# SOUL_PATH=$HOME/.local/share/muffs/workspace/memory/soul.md
# IDENTITY_PATH=$HOME/.local/share/muffs/workspace/memory/identity.md
# PERSONALITY_PATH=$HOME/.local/share/muffs/workspace/memory/personality.md

# Python agent base URL (Next.js server → FastAPI). Defaults match `muffs-agent` (8141).
PYTHON_AGENT_URL=http://127.0.0.1:8141

# Public dashboard origin (webhook hints, Settings). Defaults match `muffs-agent` (3141).
NEXT_PUBLIC_APP_URL=http://localhost:3141

# Optional: override ports for `muffs-agent` (defaults: 8141 agent, 3141 dashboard)
# MUFFS_AGENT_PORT=8141
# MUFFS_DASHBOARD_PORT=3141
