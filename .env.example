# Anthropic — Claude Agent SDK
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Composio — MCP tool connectivity and OAuth
COMPOSIO_API_KEY=your_composio_api_key_here

# Sendblue — iMessage / SMS bridge
SENDBLUE_API_KEY_ID=your_sendblue_api_key_id
SENDBLUE_API_SECRET_KEY=your_sendblue_api_secret_key
# The Sendblue number Muffs sends FROM (E.164 format, e.g. +15551234567)
SENDBLUE_FROM_NUMBER=+15551234567
# Your iPhone number Muffs sends TO (E.164 format)
SENDBLUE_TO_NUMBER=+15559876543

# Database — path to SQLite file (shared between Python agent and Next.js)
DB_PATH=./muffs.db

# Python agent base URL (Next.js calls this to trigger agent runs)
PYTHON_AGENT_URL=http://localhost:8000

# Next.js public URL (used to auto-populate the Sendblue webhook URL in Settings)
NEXT_PUBLIC_APP_URL=http://localhost:3000
